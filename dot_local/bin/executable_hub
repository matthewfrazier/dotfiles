#!/usr/bin/env bash
# hub — token-lean agent-mail CLI. Digest-first reads, one-line ops.
#   hub inbox            unread digest: "<id> <from>: <subject>"
#   hub read <id>        full body of one message
#   hub send <to>[,to2] <subject> [body]   (body from stdin if omitted; use "-" to force stdin)
#   hub ack <id>...      acknowledge (mark handled)
#   hub peers            roster one-liners
#   hub motd             fleet message of the day (daily updates + reminders)
#   hub up               sync this box: dotfiles + marketplace + plugin (restart session after)
# companion: hub-handler — launch this host's persistent Sonnet handler (tmux window)
set -uo pipefail
# HUB_ENV overrides which identity file to use — for hosts running multiple bus identities (e.g.
# raserver-IT default + raserver-homelab fleet-controller): HUB_ENV=~/.config/agent-mail/homelab.env hub send ...
ENV_FILE="${HUB_ENV:-$HOME/.config/agent-mail.env}"
. "$ENV_FILE" 2>/dev/null || { echo "hub: no $ENV_FILE (enroll first, or check HUB_ENV)" >&2; exit 1; }
API="https://agent-hub.tailbe5094.ts.net/api/"
rpc(){ curl -s -m12 -H "Content-Type: application/json" -H "Accept: application/json, text/event-stream" \
  -H "Authorization: Bearer $AGENT_MAIL_JWT" \
  -d "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"$1\",\"params\":$2}" "$API"; }
tool(){ local r; r="$(rpc tools/call "{\"name\":\"$1\",\"arguments\":$2}")"
  if printf '%s' "$r" | jq -e '.error' >/dev/null 2>&1; then printf '%s\n' "$r" | jq -r '.error.message' >&2; return 1; fi
  # MCP tool errors come back as result.isError (not JSON-RPC .error) — surface them, don't swallow
  if printf '%s' "$r" | jq -e '.result.isError==true' >/dev/null 2>&1; then printf '%s\n' "$r" | jq -r '.result.content[0].text' >&2; return 1; fi
  printf '%s' "$r" | jq -r '.result.content[0].text // empty'; }

cmd="${1:-inbox}"; shift || true
case "$cmd" in
  inbox)
    tool fetch_inbox "$(jq -nc --arg p "$AGENT_MAIL_PROJECT" --arg n "$AGENT_MAIL_NAME" --arg t "$AGENT_MAIL_TOKEN" \
      '{project_key:$p,agent_name:$n,registration_token:$t,unread_only:true,include_bodies:false,limit:20}')" \
      | jq -r '.[]? | "\(.id) \(.from): \(.subject)"'
    ;;
  read)
    [ -n "${1:-}" ] || { echo "usage: hub read <id>" >&2; exit 2; }
    tool fetch_inbox "$(jq -nc --arg p "$AGENT_MAIL_PROJECT" --arg n "$AGENT_MAIL_NAME" --arg t "$AGENT_MAIL_TOKEN" \
      '{project_key:$p,agent_name:$n,registration_token:$t,unread_only:false,include_bodies:true,limit:50}')" \
      | jq -r --argjson id "$1" '.[]? | select(.id==$id) | "FROM \(.from) [\(.subject)]\n\(.body_md)"'
    ;;
  send)
    to="${1:-}"; subj="${2:-}"; [ -n "$to" ] && [ -n "$subj" ] || { echo "usage: hub send <to>[,to] <subject> [body]" >&2; exit 2; }
    body="${3:-}"; { [ -z "$body" ] || [ "$body" = "-" ]; } && [ ! -t 0 ] && body="$(cat)"
    # server caps subject ~180 chars and SILENTLY truncates. Never lose text: if the subject is
    # oversized, keep the full text in the body and use a short preview as the subject.
    if [ "${#subj}" -gt 160 ]; then
      full="$subj"; subj="$(printf '%s' "$subj" | head -c 60 | tr '\n' ' ' | sed 's/[[:space:]]*$//')…"
      if [ -z "$body" ]; then body="$full"; else body="$full

$body"; fi
      echo "hub: subject >160 chars — moved full text to body, subject is now a preview (use a short TYPE: subject)" >&2
    fi
    tool send_message "$(jq -nc --arg p "$AGENT_MAIL_PROJECT" --arg n "$AGENT_MAIL_NAME" --arg t "$AGENT_MAIL_TOKEN" \
      --arg to "$to" --arg s "$subj" --arg b "$body" \
      '{project_key:$p,sender_name:$n,sender_token:$t,to:($to|split(",")),subject:$s,body_md:$b}')" \
      | jq -r 'if .deliveries then "sent \(.deliveries[0].payload.id) -> \(.deliveries[0].payload.to|join(","))" else . end' 2>/dev/null
    ;;
  ack)
    [ -n "${1:-}" ] || { echo "usage: hub ack <id>..." >&2; exit 2; }
    for id in "$@"; do
      tool acknowledge_message "$(jq -nc --arg p "$AGENT_MAIL_PROJECT" --arg n "$AGENT_MAIL_NAME" --arg t "$AGENT_MAIL_TOKEN" --argjson i "$id" \
        '{project_key:$p,agent_name:$n,registration_token:$t,message_id:$i}')" | jq -r '"acked \(.message_id)"' 2>/dev/null
    done
    ;;
  up)
    # one-shot client sync: dotfiles + marketplace clone + plugin
    "$HOME/.local/bin/chezmoi" update 2>/dev/null | tail -1
    mp="$HOME/.local/share/agent-hub-marketplace"
    [ -d "$mp/.git" ] && GIT_SSH_COMMAND="ssh -i $HOME/.ssh/agent-hub-deploy -o IdentitiesOnly=yes -o BatchMode=yes" git -C "$mp" pull -q 2>/dev/null && echo "marketplace pulled"
    command -v claude >/dev/null 2>&1 && { claude plugin marketplace update matthewfrazier >/dev/null 2>&1; claude plugin update agent-hub@matthewfrazier 2>&1 | tail -1; }
    echo "hub up done — restart the session to load changes"
    ;;
  motd)
    curl -fsSL -m5 https://agent-hub.tailbe5094.ts.net:8444/motd.txt 2>/dev/null || echo "hub: motd unreachable" >&2
    ;;
  peers)
    slug="$(printf '%s' "$AGENT_MAIL_PROJECT" | sed 's#^/##; s#/#-#g')"
    rpc resources/read "{\"uri\":\"resource://agents/$slug\"}" \
      | jq -r '.result.contents[0].text' | jq -r '.agents[]? | "\(.name) [\(.task_description // "-")]"'
    ;;
  *) sed -n '3,8p' "$0" | sed 's/^# \{0,3\}//' ;;
esac
