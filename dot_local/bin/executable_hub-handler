#!/usr/bin/env bash
# hub-handler — stand up this host's persistent handler in a dedicated tmux window.
# <host>-handler identity, Sonnet, event-driven. Owns routine bus directives + host-local capabilities.
# Role: https://agent-hub.tailbe5094.ts.net:8444/handler-role.md
set -uo pipefail
. "$HOME/.config/agent-mail.env" 2>/dev/null || { echo "hub-handler: enroll first (no agent-mail.env)" >&2; exit 1; }
host="$(printf '%s' "$(hostname -s 2>/dev/null || hostname)" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9' '-' | sed 's/-\{1,\}/-/g;s/^-//;s/-$//')"
win="handler"
# target a tmux session even when invoked from outside tmux (attached session, else first, else create)
if [ -n "${TMUX:-}" ]; then sess=""            # inside tmux: current session
elif sess="$(tmux list-clients -F '#{session_name}' 2>/dev/null | head -1)"; [ -n "$sess" ]; then :   # an attached session
elif sess="$(tmux list-sessions -F '#{session_name}' 2>/dev/null | head -1)"; [ -n "$sess" ]; then :   # any session
else tmux new-session -d -s hub -c "$HOME"; sess=hub; fi                                                # none: make one
tgt="${sess:+$sess:}"

if tmux list-windows ${sess:+-t "$sess"} -F '#W' 2>/dev/null | grep -qx "$win"; then
  echo "handler window already exists"; exit 0
fi
tmux new-window ${tgt:+-t "$tgt"} -n "$win" -c "$HOME" \
  "AGENT_NAME='${host}-handler' claude --model sonnet 'You are ${host}-handler. Read your standing role: curl -fsSL https://agent-hub.tailbe5094.ts.net:8444/handler-role.md . Then: hub up if directed, watch the bus event-only, handle routine directives for this host + host-local capability requests, escalate heavy work. Start by running: hub motd ; hub inbox'"
echo "handler launched in tmux window '$win' as ${host}-handler (sonnet)"
